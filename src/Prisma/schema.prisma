generator client {
  provider = "prisma-client-js"
}

// Conexão PostgreSQL no Docker
datasource db {
  provider = "postgresql"
}


// Tabela de Eventos
model Event {
  id          String   @id @default(uuid())
  name        String
  totalSeats  Int      // Quantidade total de ingressos disponíveis
  date        DateTime

  // Relacionamento: Um evento tem VÁRIOS ingressos (1 para N)
  tickets     Ticket[] 

  @@map("events")
}

// Tabela de Ingressos (O Estoque Físico/Virtual)
model Ticket {
  id          String   @id @default(uuid())
  seat        String   // Ex: "Cadeira A42"
  price       Float
  status      TicketStatus @default(AVAILABLE) // Enum para controlar o estado da máquina
  
  // Relacionamentos
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  
  transactions Transaction[]

  @@map("tickets")
}

// Tabela de Transações
model Transaction {
  id              String   @id @default(uuid())
  idempotencyKey  String   @unique
  customerEmail   String   // <--- ESSA LINHA PRECISA ESTAR AQUI E SALVA
  amount          Float
  status          String
  createdAt       DateTime @default(now())

  // Relacionamento
  ticketId        String
  ticket          Ticket   @relation(fields: [ticketId], references: [id])

  @@map("transactions")
}

// Enums para forçar o status dos ingressos a ser apenas um desses 3 valores
enum TicketStatus {
  AVAILABLE
  RESERVED
  SOLD
}